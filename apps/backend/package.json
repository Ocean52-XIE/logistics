{
  "name": "@logistics/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "tsx watch -r dotenv/config src/main.ts",
    "start:test": "tsx -r dotenv/config src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node -r dotenv/config dist/apps/backend/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/test/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@logistics/shared": "0.1.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.15.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.15.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
