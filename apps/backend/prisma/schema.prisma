generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  manager
  trainer
  admin
}

enum CourseRequirement {
  required
  optional
}

enum CourseStatus {
  draft
  published
}

enum LearningContentType {
  video
  article
  pdf
  quiz
}

model User {
  id               String             @id
  username         String             @unique
  passwordHash     String
  name             String
  role             UserRole           @default(employee)
  organizationName String
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  examAttempts     ExamAttempt[]
  learningProgress LearningProgress[]
  trainingPlanAssignments TrainingPlanAssignment[]
  userNotifications UserNotification[]
}

model Course {
  id               String             @id
  title            String
  category         String
  durationMinutes  Int
  requirement      CourseRequirement
  dueDate          DateTime
  description      String
  roles            Json
  completionRule   String
  attachments      Json
  status           CourseStatus       @default(draft)
  publishedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  lessons          Lesson[]
  learningProgress LearningProgress[]
  trainingPlanCourses TrainingPlanCourse[]
}

model Lesson {
  id               String             @id
  courseId         String
  title            String
  contentType      LearningContentType
  content          String
  totalSeconds     Int
  sortOrder        Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  course           Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningProgress LearningProgress[]

  @@index([courseId, sortOrder])
}

model Exam {
  id              String        @id
  name            String
  durationMinutes Int
  startTime       DateTime
  passScore       Int
  instructions    String
  warnings        Json
  questions       Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  attempts        ExamAttempt[]
}

model ExamAttempt {
  id               String   @id @default(cuid())
  examId           String
  userId           String
  answers          Json
  currentQuestion  Int      @default(1)
  remainingSeconds Int
  savedAt          DateTime?
  submittedAt      DateTime?
  score            Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  exam             Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
  @@index([userId])
}

model LearningProgress {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  lessonId        String
  positionSeconds Int      @default(0)
  completed       Boolean  @default(false)
  lastLearnedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

model TrainingPlan {
  id          String                    @id @default(cuid())
  name        String
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  courses     TrainingPlanCourse[]
  assignments TrainingPlanAssignment[]
}

model TrainingPlanCourse {
  id        String       @id @default(cuid())
  planId    String
  courseId  String
  createdAt DateTime     @default(now())
  plan      TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([planId, courseId])
  @@index([courseId])
}

model TrainingPlanAssignment {
  id          String       @id @default(cuid())
  planId       String
  userId       String
  assignedAt   DateTime    @default(now())
  completedAt  DateTime?
  plan         TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([planId, userId])
  @@index([userId])
}

model KnowledgeArticle {
  id               String   @id
  title            String
  category         String
  summary          String
  content          String
  tags             Json
  relatedCourseIds Json
  isHot            Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id                String             @id
  title             String
  content           String
  pinned            Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userNotifications UserNotification[]
}

model UserNotification {
  id             String       @id @default(cuid())
  userId         String
  notificationId String
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([notificationId])
}
